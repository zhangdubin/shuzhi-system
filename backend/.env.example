# ============================================================
# 数智化管理系统 - 后端环境变量样例
# ============================================================
# 用法：cp .env.example .env，然后填入真实值
# 切勿把 .env 提交到 Git（已在 .gitignore 里）

# ===== 应用 =====
APP_NAME=数智化管理系统
APP_VERSION=1.0.0

# ===== GitHub Release（系统更新检查）=====
# 修改后需重启后端容器生效
GITHUB_REPO_OWNER=trisome
GITHUB_REPO_NAME=shuzhi-system
GITHUB_API_BASE=https://api.github.com
# 可选：GitHub Personal Access Token（无任何 scope 即可）
# - Private 仓库必须填写
# - 公开仓库可留空，但填写后限额 60/h → 5000/h
# - 申请地址：https://github.com/settings/tokens/new
GITHUB_TOKEN=
ENV=development
DEBUG=False
LOG_LEVEL=INFO

# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://shuzhi:shuzhi@localhost:5432/shuzhi
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ===== Redis =====
REDIS_URL=redis://:shuzhi@localhost:6379/0

# ===== JWT 安全 =====
JWT_SECRET_KEY=change-me-to-a-64-char-random-string-please-do-not-use-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ===== CORS =====
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ===== OCR 识别 =====
OCR_SERVICE_URL=http://localhost:8001
OCR_MODE=real
OCR_CONFIDENCE_THRESHOLD=0.85
OCR_TIMEOUT=30

# ===== 诺诺发票云（开发替身）=====
NUONUO_MODE=mock
NUONUO_API_URL=http://localhost:8002/open/v1/services
NUONUO_USE_SANDBOX=True
NUONUO_API_KEY=
NUONUO_API_SECRET=
NUONUO_API_TOKEN=

# ===== 企业微信 SSO =====
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=

# ===== AI 平台 =====
AI_ENABLED=True
AI_LLM_MODEL=gpt-4o-mini
AI_LLM_ENDPOINT=https://api.openai.com/v1
AI_LLM_API_KEY=
AI_DEFAULT_TIMEOUT=30
AI_MAX_FILE_SIZE_MB=10
AI_RATE_LIMIT_PER_USER_PER_MIN=20
AI_RATE_LIMIT_PER_TENANT_PER_HOUR=500
AI_COST_LIMIT_PER_TENANT_PER_DAY_CENTS=50000

# ===== 对象存储 MinIO =====
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=shuzhi
MINIO_SECRET_KEY=shuzhi
MINIO_BUCKET=shuzhi
MINIO_REGION=us-east-1
MINIO_SECURE=False

# ===== Sentry 监控（可选）=====
SENTRY_DSN=

# ===== Grafana（容器间通信）=====
GRAFANA_PASSWORD=shuzhi
