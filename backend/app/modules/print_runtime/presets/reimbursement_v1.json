{
  "version": "1.0",
  "meta": {
    "docType": "reimbursement",
    "title": "费用报销单",
    "description": "报销单 A4 标准版（含明细表）"
  },
  "paper": { "size": "A4", "orientation": "portrait", "marginMm": { "top": 18, "right": 18, "bottom": 18, "left": 18 } },
  "schemaJson": {
    "body": [
      { "type": "title", "text": "费 用 报 销 单", "fontSize": 22, "align": "center" },
      { "type": "text", "text": "{{ company.name }} · 报销编号：{{ form.formNo | default('—') }}", "fontSize": 10, "align": "center", "color": "#6B7280" },
      { "type": "spacer", "height": 8 },
      { "type": "line" },
      { "type": "spacer", "height": 4 },
      { "type": "text", "text": "申请人：{{ form.applicant.name | default('—') }}", "fontSize": 11 },
      { "type": "text", "text": "部门：{{ form.department.name | default('—') }}", "fontSize": 11 },
      { "type": "text", "text": "申请日期：{{ form.expenseDate | default('—') }}", "fontSize": 11 },
      { "type": "text", "text": "状态：{{ form.statusLabel | default('—') }}", "fontSize": 11 },
      { "type": "spacer", "height": 4 },
      { "type": "line" },
      { "type": "spacer", "height": 4 },
      { "type": "text", "text": "报销明细（共 {{ form.detailCount | default(0) }} 项）", "fontSize": 13, "color": "#4F6BFF" },
      { "type": "spacer", "height": 4 },
      {
        "type": "table",
        "bind": "form.details",
        "columns": [
          { "key": "expenseDate", "label": "日期", "width": 22, "type": "string" },
          { "key": "expenseType", "label": "类型", "width": 18, "type": "string" },
          { "key": "title", "label": "事项", "width": 50, "type": "string" },
          { "key": "amount", "label": "金额", "width": 25, "type": "money" }
        ]
      },
      { "type": "spacer", "height": 6 },
      { "type": "text", "text": "报销总额：¥ {{ form.totalAmount | default(0) }}（大写：{{ form.totalAmount | chinese_money }}）", "fontSize": 13, "color": "#DC2626" },
      { "type": "text", "text": "实付金额：¥ {{ form.actualAmount | default(0) }}", "fontSize": 12 },
      { "type": "spacer", "height": 6 },
      { "type": "line" },
      { "type": "spacer", "height": 4 },
      { "type": "text", "text": "备注：{{ form.remark | default('（无）') }}", "fontSize": 10 },
      { "type": "text", "text": "AI 风险提示：{{ form.aiRiskReason | default('（无）') }}", "fontSize": 10, "color": "#F59E0B" },
      { "type": "spacer", "height": 16 },
      { "type": "text", "text": "打印时间：{{ printTime }} | 打印人：{{ printUser }}", "fontSize": 9, "align": "center", "color": "#9CA3AF" }
    ]
  }
}
