# ============================================================
# 环境变量样例 - 复制到 .env
# ============================================================

# ===== 应用 =====
ENV=development
LOG_LEVEL=INFO

# ===== 安全（必改）=====
JWT_SECRET_KEY=please-change-this-to-a-very-long-random-string-at-least-64-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== 数据库 =====
POSTGRES_USER=shuzhi
POSTGRES_PASSWORD=shuzhi
POSTGRES_DB=shuzhi
DATABASE_URL=postgresql+asyncpg://shuzhi:shuzhi@postgres:5432/shuzhi

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== OCR 服务 =====
OCR_SERVICE_URL=http://ocr-service:8001
OCR_DEFAULT_ENGINE=paddleocr
OCR_CONFIDENCE_THRESHOLD=0.90

# ===== 诺诺发票云（合规查验）=====
NUONUO_API_KEY=your-nuonuo-api-key
NUONUO_API_SECRET=your-nuonuo-api-secret
NUONUO_FREE_QUOTA=200

# ===== 监控 =====
SENTRY_DSN=
GRAFANA_PASSWORD=admin

# ===== 对象存储 =====
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=shuzhi-uploads
OSS_ENDPOINT=

# ===== 短信 =====
SMS_ACCESS_KEY=
SMS_SIGN_NAME=数智化系统
