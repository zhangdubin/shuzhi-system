  },
  "description": "数智化系统 · 核心监控面板（R7.2 完整版：业务指标 + HTTP 性能 + 慢请求 + 容器）",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "iteration": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "🚦 HTTP 请求量（req/s）",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(shuzhi_http_requests_total{job=\"backend\"}[1m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineWidth": 2}},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "title": "⏱️ P50 / P95 / P99 延迟",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.5, sum(rate(shuzhi_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(shuzhi_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(shuzhi_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99", "refId": "C"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineWidth": 2}},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "title": "🔥 5xx 错误率",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(shuzhi_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(shuzhi_http_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      }
    },
    {
      "title": "🐢 慢请求（>500ms）",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(shuzhi_http_slow_requests_total[5m])) * 60",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        }
      }
    },
    {
      "title": "🔄 在飞请求",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "shuzhi_http_in_flight_requests",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 100}
            ]
          }
        }
      }
    },
    {
      "title": "📊 HTTP 状态码分布",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(shuzhi_http_requests_total[1m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineWidth": 2}},
        "overrides": []
      }
    },
    {
      "title": "🔍 OCR 识别数",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "sum(rate(shuzhi_business_ocr_total[5m])) by (status, mode)",
          "legendFormat": "{{mode}} / {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2}},
        "overrides": []
      }
    },
    {
      "title": "✅ 诺诺验真数",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
      "targets": [
        {
          "expr": "sum(rate(shuzhi_business_verify_total[5m])) by (result, mode)",
          "legendFormat": "{{mode}} / {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2}},
        "overrides": []
      }
    },
    {
      "title": "🤖 AI 调用 + 缓存命中率",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
      "targets": [
        {
          "expr": "sum(rate(shuzhi_business_ai_total[5m])) by (type, cache)",
          "legendFormat": "{{type}} / {{cache}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2}},
        "overrides": []
      }
    },
    {
      "title": "🔐 登录（成功 vs 失败）",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "sum(rate(shuzhi_business_login_total[5m])) by (method, result)",
          "legendFormat": "{{method}} / {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2}},
        "overrides": []
      }
    },
    {
      "title": "🗄️ PostgreSQL 连接数",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "活跃连接",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"drawStyle": "line", "lineWidth": 2}},
        "overrides": []
      }
    },
    {
      "title": "💾 Redis 内存使用",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 28},
      "targets": [
        {
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.6},
              {"color": "red", "value": 0.8}
            ]
          }
        }
      }
    },
    {
      "title": "🖥️ 主机 CPU",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 28},
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU 使用率",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"drawStyle": "line", "lineWidth": 2}},
        "overrides": []
      }
    },
    {
      "title": "🧠 主机内存",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 28},
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "内存使用率",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"drawStyle": "line", "lineWidth": 2}},
        "overrides": []
      }
    }
  ],
